# Frontend (Vite) environment
VITE_MODE=live
VITE_API_URL=http://localhost:3001

# ── LLM backend (choose one) ──────────────────────────────────────────
# Default: local Ollama/Qwen
VITE_LLM_PROVIDER=ollama
VITE_OLLAMA_URL=http://localhost:11434
VITE_QWEN_MODEL=qwen2.5:7b

# Alternative: Anthropic Claude API (fastest + highest quality; ~$0.01-0.04/contract)
# Uncomment and set VITE_ANTHROPIC_API_KEY to flip backends.
# NOTE: API key ships in the client bundle — acceptable for personal demo laptop,
#       NOT for Pages deploy. For prod, proxy through the server instead.
# VITE_LLM_PROVIDER=anthropic
# VITE_ANTHROPIC_API_KEY=sk-ant-api03-...
# VITE_ANTHROPIC_MODEL=claude-haiku-4-5     # or claude-sonnet-4-6 for higher quality
